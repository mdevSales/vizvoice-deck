    {
      "title": "The live demo",
      "narration": "Here is a real exchange with the agent. You ask which line had the most cancellations. Route twelve, two hundred and fifty canceled trips. You ask about the Green Line in December. Thirty-seven. Every answer grounded in the live semantic model.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
