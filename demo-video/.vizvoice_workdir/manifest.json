        "wait: 3"
      ],
      "requests": [],
      "console": []
    },
    {
      "title": "253 million",
      "narration": "Two hundred and fifty-three million people with vision impairment have zero independent access to these insights. That is the size of the gap we are closing.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
