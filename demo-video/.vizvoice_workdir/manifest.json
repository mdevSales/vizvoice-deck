    },
    {
      "title": "The critique",
      "narration": "Every accessibility fix in the industry today assumes the goal is reading the chart. We think that assumption is the bug.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
      "source_hash": "77e32be05fd8b69c",
      "duration": 7.3227,
      "start_offset": 34.249988167,
      "actions": [
        "press: ArrowRight",
        "wait: 3"
      ],
      "requests": [],
      "console": []
    },
    {
      "title": "The reframe",
      "narration": "What if you did not need to see the chart at all? What if the dashboard just answered you?",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
      "source_hash": "77e32be05fd8b69c",
      "duration": 5.04,
