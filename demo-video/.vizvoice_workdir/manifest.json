      ],
      "requests": [],
      "console": []
    },
    {
      "title": "The semantic model",
      "narration": "The agent reasons over the same Data 360 semantic model that renders every chart in the org. No RAG, no custom index, no drift between what a sighted user sees and what a blind user hears \u2014 one definition, honored by both.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
      "source_hash": "77e32be05fd8b69c",
      "duration": 15.9627,
