      "requests": [],
      "console": []
    },
    {
      "title": "The solution",
      "narration": "Ask the dashboard out loud. Hear the answer back. That is VizVoice \u2014 a voice-first agent built on Data 360 and Agentforce.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
      "source_hash": "77e32be05fd8b69c",
      "duration": 9.2693,
      "start_offset": 47.4410805,
