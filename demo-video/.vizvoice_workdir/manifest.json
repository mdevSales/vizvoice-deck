    {
      "title": "Three layers of work",
      "narration": "We did not just make VizVoice compliant. We trained the analytics agent with strict accessibility rules in its system prompt. We ran the accessibility expert skill against every component. And we redesigned the entire interaction around voice.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
