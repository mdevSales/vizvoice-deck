    {
      "title": "The scene",
      "narration": "Traditional Tableau dashboards render as unlabeled SVG. To a screen reader, they are silent \u2014 a wall of shapes with no data behind them.",
      "scene": "browser",
      "layout": "",
      "surface": "",
      "ftest_source": "",
      "source_hash": "77e32be05fd8b69c",
      "duration": 8.6454,
